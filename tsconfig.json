{
  "extends": "./config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@main/*": ["./src/main/*"],
      "@preload/*": ["./src/preload/*"],
      "@shared": ["./src/shared/index.ts"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "config/**/*",
    "*.ts",
    "*.mjs",
    "*.cjs"
  ],
  "exclude": ["node_modules", "out", "dist", "dist-web"]
}
